{
  "name": "praxis-kit",
  "private": true,
  "version": "3.2.0",
  "description": "Praxis Kit — framework-neutral component infrastructure with enforced structural contracts, ARIA validation, and polymorphic rendering.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm typecheck && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "test:ci": "pnpm -r --if-present test",
    "test:related": "pnpm -r --if-present test:related",
    "bench": "pnpm --filter @praxis-kit/bench bench",
    "bench:render": "pnpm --filter @praxis-kit/bench bench:render",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:staged": "git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' | xargs eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.md' | xargs prettier --write",
    "clean": "rm -rf node_modules packages/**/node_modules packages/**/dist",
    "prepare": "husky",
    "repo-state": "node --experimental-strip-types scripts/generate-repo-state.ts",
    "arch:validate": "depcruise --config .dependency-cruiser.cjs lib packages",
    "analyze:deps": "depcruise --config .dependency-cruiser.cjs lib packages",
    "analyze:duplicates": "jscpd --config .jscpd.json",
    "analyze:patterns": "sh scripts/ast-grep.sh scan --config .ast-grep/sgconfig.yml",
    "analyze": "pnpm --filter @praxis-kit/bundle-analysis analyze",
    "size": "pnpm --filter @praxis-kit/bundle-analysis size",
    "lint:pkg": "pnpm -r --if-present lint:pkg",
    "metrics": "pnpm --filter @praxis-kit/metrics metrics",
    "metrics:collect": "pnpm --filter @praxis-kit/metrics collect",
    "metrics:report": "pnpm --filter @praxis-kit/metrics report",
    "metrics:assert": "pnpm --filter @praxis-kit/metrics assert"
  },
  "devDependencies": {
    "@ast-grep/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@vitest/ui": "catalog:",
    "dependency-cruiser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-boundaries": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "husky": "catalog:",
    "jiti": "catalog:",
    "jscpd": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "publint": "^0.3.21",
    "ts-morph": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24"
  },
  "author": "K Huehn <slowebworkz@gmail.com>"
}
