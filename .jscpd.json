{
  "threshold": 15,
  "reporters": ["consoleFull"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.bench.ts",
    "**/snapshots/**",
    "**/scenarios/**"
  ],
  "languages": ["typescript"],
  "minLines": 12,
  "minTokens": 70,
  "gitignore": true,
  "noSymlinks": true,
  "path": ["lib", "packages"],
  "format": ["typescript"]
}
