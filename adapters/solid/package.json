{
  "name": "@praxis-kit/solid",
  "version": "0.8.0-beta.4",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed --config vitest.config.ts && vitest run --changed --config vitest.ssr.config.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "solid-js": ">=1.6"
  },
  "devDependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "@solidjs/testing-library": "catalog:",
    "jsdom": "catalog:",
    "solid-js": "catalog:",
    "vite-plugin-solid": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "adapters/solid"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/adapters/solid#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit adapter for SolidJS — polymorphic components with ARIA contracts and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "solid-js",
    "solidjs"
  ],
  "engines": {
    "node": ">=18"
  }
}
