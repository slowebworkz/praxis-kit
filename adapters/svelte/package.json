{
  "name": "@praxis-kit/svelte",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Polymorphic.svelte": {
      "svelte": "./src/Polymorphic.svelte"
    }
  },
  "files": [
    "dist",
    "src/Polymorphic.svelte",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed --config vitest.config.ts && vitest run --changed --config vitest.ssr.config.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@praxis-kit/primitive": "workspace:*",
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "@praxis-kit/diagnostics": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "catalog:",
    "jsdom": "catalog:",
    "svelte": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "adapters/svelte"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/adapters/svelte#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit adapter for Svelte 5 — polymorphic components with ARIA contracts and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "svelte"
  ],
  "engines": {
    "node": ">=18"
  }
}
