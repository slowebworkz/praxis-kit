{
  "name": "@praxis-kit/bundle-analysis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Bundle composition analysis for all published packages",
  "scripts": {
    "analyze": "rollup --config rollup.config.ts --configPlugin rollup-plugin-esbuild",
    "size": "size-limit",
    "size:ci": "size-limit --json"
  },
  "dependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "@praxis-kit/core": "workspace:*",
    "@praxis-kit/preact": "workspace:*",
    "@praxis-kit/react": "workspace:*",
    "@praxis-kit/solid": "workspace:*",
    "@praxis-kit/svelte": "workspace:*",
    "@praxis-kit/tailwind": "workspace:*",
    "@praxis-kit/vue": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@size-limit/preset-small-lib": "^12.1.0",
    "rollup": "^4.61.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0"
  }
}
