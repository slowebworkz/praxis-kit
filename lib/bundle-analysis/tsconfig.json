{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@polymorphic-ui/core": ["../../packages/core/src/index.ts"],
      "@polymorphic-ui/core/primitive": [
        "../../packages/core/src/primitive.ts"
      ],
      "@polymorphic-ui/core/contract": ["../../packages/core/src/contract.ts"],
      "@polymorphic-ui/core/styling": ["../../packages/core/src/styling.ts"],
      "@polymorphic-ui/primitive": ["../primitive/src"],
      "@polymorphic-ui/contract": ["../contract/src"],
      "@polymorphic-ui/styling": ["../styling/src"],
      "@polymorphic-ui/adapter-utils": ["../adapter-utils/src"],
      "@polymorphic-ui/react": ["../../packages/react/src/index.ts"],
      "@polymorphic-ui/vue": ["../../packages/vue/src/index.ts"],
      "@polymorphic-ui/solid": ["../../packages/solid/src/index.ts"],
      "@polymorphic-ui/preact": ["../../packages/preact/src/index.ts"],
      "@polymorphic-ui/svelte": ["../../packages/svelte/src/index.ts"],
      "@polymorphic-ui/tailwind": ["../../packages/tailwind/src/index.ts"],
      "@/shared": ["../../packages/react/src/shared"],
      "@/shared/*": ["../../packages/react/src/shared/*"],
      "@/current": ["../../packages/react/src/current"],
      "@/current/*": ["../../packages/react/src/current/*"]
    }
  },
  "include": ["rollup.config.ts", "src/**/*.ts"]
}
