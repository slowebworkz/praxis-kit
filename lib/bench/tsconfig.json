{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@praxis-ui/core": ["../../packages/core/src/index.ts"],
      "@praxis-ui/core/primitive": ["../../packages/core/src/primitive.ts"],
      "@praxis-ui/core/contract": ["../../packages/core/src/contract.ts"],
      "@praxis-ui/core/styling": ["../../packages/core/src/styling.ts"],
      "@praxis-ui/react": ["../../packages/react/src/index.ts"],
      "@praxis-ui/primitive": ["../primitive/src"],
