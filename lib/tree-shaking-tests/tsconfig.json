{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@praxis-ui/core": ["../../packages/core/src/index.ts"],
      "@praxis-ui/core/primitive": ["../../packages/core/src/primitive.ts"],
      "@praxis-ui/core/contract": ["../../packages/core/src/contract.ts"],
      "@praxis-ui/core/styling": ["../../packages/core/src/styling.ts"],
      "@praxis-ui/primitive": ["../../lib/primitive/src/index.ts"],
      "@praxis-ui/contract": ["../../lib/contract/src/index.ts"],
      "@praxis-ui/styling": ["../../lib/styling/src/index.ts"],
      "@praxis-ui/adapter-utils": ["../../lib/adapter-utils/src/index.ts"],
      "@praxis-ui/react": ["../../packages/react/src/index.ts"],
      "@praxis-ui/vue": ["../../packages/vue/src/index.ts"],
      "@praxis-ui/solid": ["../../packages/solid/src/index.ts"],
      "@praxis-ui/preact": ["../../packages/preact/src/index.ts"],
      "@praxis-ui/svelte": ["../../packages/svelte/src/index.ts"],
      "@praxis-ui/tailwind": ["../../packages/tailwind/src/index.ts"],
      "@/shared": ["../../packages/react/src/shared"],
      "@/shared/*": ["../../packages/react/src/shared/*"],
      "@/current": ["../../packages/react/src/current"],
      "@/current/*": ["../../packages/react/src/current/*"]
    }
  },
  "include": ["scripts/**/*", "scenarios/**/*"],
  "exclude": [
    "scenarios/solid-minimal",
    "scenarios/vue-minimal",
    "scenarios/preact-minimal",
    "scenarios/svelte-minimal"
  ]
}
