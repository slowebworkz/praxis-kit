{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "@polymorphic-ui/core": ["./packages/core/src"],
      "@polymorphic-ui/core/primitive": ["./packages/core/src/primitive.ts"],
      "@polymorphic-ui/core/contract": ["./packages/core/src/contract.ts"],
      "@polymorphic-ui/core/styling": ["./packages/core/src/styling.ts"],
      "@polymorphic-ui/primitive": ["./lib/primitive/src"],
      "@polymorphic-ui/contract": ["./lib/contract/src"],
      "@polymorphic-ui/styling": ["./lib/styling/src"],
      "@polymorphic-ui/adapter-utils": ["./lib/adapter-utils/src"]
    }
  }
}
