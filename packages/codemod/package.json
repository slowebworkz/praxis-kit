{
  "name": "@praxis-kit/codemod",
  "version": "3.0.1",
  "type": "module",
  "bin": {
    "praxis-codemod": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ts-morph": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/codemod"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/codemod#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Codemods for migrating between Praxis Kit versions",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "codemod",
    "migration",
    "cli"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
