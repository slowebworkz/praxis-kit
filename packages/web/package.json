{
  "name": "@praxis-kit/web",
  "version": "3.0.3",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed && vitest run --changed --config vitest.ssr.config.ts",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "type-fest": "catalog:"
  },
  "devDependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "jsdom": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/web#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit vanilla Custom Elements adapter — framework-free polymorphic components with ARIA contracts",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "web-components",
    "custom-elements",
    "vanilla"
  ],
  "engines": {
    "node": ">=18"
  }
}
