{
  "name": "@praxis-kit/preact",
  "version": "3.0.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "preact": ">=10.11"
  },
  "devDependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "jsdom": "catalog:",
    "preact": "catalog:",
    "preact-render-to-string": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/preact"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/preact#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit adapter for Preact — polymorphic components with ARIA contracts and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "preact"
  ],
  "engines": {
    "node": ">=18"
  }
}
