{
  "name": "@praxis-ui/preact",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@praxis-ui/core": "workspace:*",
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "preact": ">=10.11"
  },
  "devDependencies": {
    "@praxis-ui/adapter-utils": "workspace:*",
    "jsdom": "catalog:",
    "preact": "catalog:",
    "preact-render-to-string": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-ui.git",
    "directory": "packages/preact"
  },
  "homepage": "https://github.com/slowebworkz/praxis-ui/tree/main/packages/preact#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-ui/issues"
