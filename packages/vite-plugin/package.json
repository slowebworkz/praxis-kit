    "prepublishOnly": "pnpm build"
  },
  "sideEffects": false,
  "peerDependencies": {
    "vite": ">=5"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@praxis-ui/core": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.14",
    "vitest": "catalog:"
  }
}
