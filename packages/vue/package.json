{
  "name": "@praxis-ui/vue",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@praxis-ui/core": "workspace:*",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "vue": ">=3.4"
  },
  "devDependencies": {
    "@praxis-ui/adapter-utils": "workspace:*",
    "@vue/server-renderer": "catalog:",
    "@vue/test-utils": "catalog:",
    "jsdom": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-ui.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/slowebworkz/praxis-ui/tree/main/packages/vue#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-ui/issues"
  },
  "license": "MIT"
}
