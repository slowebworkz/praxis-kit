{
  "name": "@polymorphic-ui/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./primitive": {
      "types": "./dist/primitive.d.ts",
      "import": "./dist/primitive.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./styling": {
      "types": "./dist/styling.d.ts",
      "import": "./dist/styling.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed"
  },
  "sideEffects": false,
  "dependencies": {
    "@polymorphic-ui/contract": "workspace:*",
    "@polymorphic-ui/primitive": "workspace:*",
    "@polymorphic-ui/styling": "workspace:*",
    "type-fest": "catalog:"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
