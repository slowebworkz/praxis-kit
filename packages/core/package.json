{
  "name": "@praxis-kit/core",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./primitive": {
      "types": "./dist/primitive.d.ts",
      "import": "./dist/primitive.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./styling": {
      "types": "./dist/styling.d.ts",
      "import": "./dist/styling.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "type-fest": "catalog:"
  },
  "devDependencies": {
    "@praxis-kit/contract": "workspace:*",
    "@praxis-kit/primitive": "workspace:*",
    "@praxis-kit/shared": "workspace:*",
    "@praxis-kit/styling": "workspace:*",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Framework-neutral UI primitive with polymorphic rendering, ARIA enforcement, and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants"
  ],
  "engines": {
    "node": ">=18"
  }
}
