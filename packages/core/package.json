{
  "name": "@praxis-ui/core",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./primitive": {
      "types": "./dist/primitive.d.ts",
      "import": "./dist/primitive.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./styling": {
      "types": "./dist/styling.d.ts",
      "import": "./dist/styling.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "type-fest": "catalog:"
  },
  "devDependencies": {
    "@praxis-ui/contract": "workspace:*",
    "@praxis-ui/primitive": "workspace:*",
    "@praxis-ui/styling": "workspace:*",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/slowebworkz/praxis-ui/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-ui/issues"
  },
  "license": "LicenseRef-PolyForm-Strict-1.0.0",
  "author": "K Huehn <slowebworkz@gmail.com>"
}
