{
  "name": "@praxis-ui/lit",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed && vitest run --changed --config vitest.ssr.config.ts",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@praxis-ui/adapter-utils": "workspace:*",
    "@praxis-ui/core": "workspace:*",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "lit": ">=3.0"
  },
  "devDependencies": {
    "jsdom": "catalog:",
    "lit": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
