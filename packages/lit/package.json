{
  "name": "@praxis-kit/lit",
  "version": "0.8.0-beta.3",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed && vitest run --changed --config vitest.ssr.config.ts",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "lit": ">=3.0"
  },
  "devDependencies": {
    "@praxis-kit/adapter-utils": "workspace:*",
    "jsdom": "catalog:",
    "lit": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/lit"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/lit#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit adapter for Lit — polymorphic custom elements with ARIA contracts and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "lit",
    "web-components",
    "custom-elements"
  ],
  "engines": {
    "node": ">=18"
  }
}
