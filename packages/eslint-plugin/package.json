{
  "name": "@praxis-ui/eslint-plugin",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@typescript-eslint/utils": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-ui.git",
    "directory": "packages/eslint-plugin"
  },
  "homepage": "https://github.com/slowebworkz/praxis-ui/tree/main/packages/eslint-plugin#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-ui/issues"
  },
  "license": "CC-BY-NC-4.0",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "ESLint rules for enforcing Praxis UI structural patterns, ARIA contracts, and variant configuration",
  "keywords": [
    "praxis-ui",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "eslint",
    "eslint-plugin",
    "linting"
  ],
  "engines": {
    "node": ">=18"
  }
}
