{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    // map private adapter-utils to source so tsup's dts bundler inlines the re-exported FilterPredicate
    // child paths replaces parent entirely — must re-declare all workspace aliases from tsconfig.paths.json
    "paths": {
      "@praxis-ui/core": ["../../packages/core/src"],
      "@praxis-ui/core/primitive": ["../../packages/core/src/primitive.ts"],
      "@praxis-ui/core/contract": ["../../packages/core/src/contract.ts"],
      "@praxis-ui/core/styling": ["../../packages/core/src/styling.ts"],
      "@praxis-ui/core/*": ["../../packages/core/src/*"],
      "@praxis-ui/primitive": ["../../lib/primitive/src"],
      "@praxis-ui/primitive/*": ["../../lib/primitive/src/*"],
      "@praxis-ui/contract": ["../../lib/contract/src"],
      "@praxis-ui/contract/*": ["../../lib/contract/src/*"],
      "@praxis-ui/styling": ["../../lib/styling/src"],
      "@praxis-ui/styling/*": ["../../lib/styling/src/*"],
      "@praxis-ui/adapter-utils": ["../../lib/adapter-utils/src"],
      "@praxis-ui/adapter-utils/*": ["../../lib/adapter-utils/src/*"]
    }
  },
  "include": ["src"]
}
