{
  "name": "@praxis-ui/svelte",
  "version": "3.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Polymorphic.svelte": {
      "svelte": "./src/Polymorphic.svelte"
    }
  },
  "files": [
    "dist",
    "src/Polymorphic.svelte",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed --config vitest.config.ts && vitest run --changed --config vitest.ssr.config.ts",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@praxis-ui/core": "workspace:*",
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@praxis-ui/adapter-utils": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "catalog:",
    "jsdom": "catalog:",
    "svelte": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-ui.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/slowebworkz/praxis-ui/tree/main/packages/svelte#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-ui/issues"
  },
  "license": "LicenseRef-PolyForm-Strict-1.0.0",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis UI adapter for Svelte 5 — polymorphic components with ARIA contracts and variant composition",
  "keywords": [
    "praxis-ui",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "svelte"
  ]
}
