{
  "name": "@polymorphic-ui/svelte",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Polymorphic.svelte": {
      "svelte": "./src/Polymorphic.svelte"
    }
  },
  "files": [
    "dist",
    "src/Polymorphic.svelte"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.ssr.config.ts",
    "test:related": "vitest run --changed --config vitest.config.ts && vitest run --changed --config vitest.ssr.config.ts",
    "prepublishOnly": "pnpm build"
  },
  "sideEffects": false,
  "dependencies": {
    "@polymorphic-ui/core": "workspace:*",
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "catalog:",
    "jsdom": "catalog:",
    "svelte": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
