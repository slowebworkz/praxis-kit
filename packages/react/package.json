{
  "name": "@praxis-kit/react",
  "version": "0.8.0-beta.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./legacy": {
      "types": "./dist/legacy/index.d.ts",
      "import": "./dist/legacy/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:pw": "playwright test -c playwright-ct.config.ts",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@playwright/experimental-ct-react": "catalog:",
    "@praxis-kit/adapter-utils": "workspace:*",
    "@praxis-kit/playwright": "workspace:*",
    "@vitejs/plugin-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "@praxis-kit/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slowebworkz/praxis-kit.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/slowebworkz/praxis-kit/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/slowebworkz/praxis-kit/issues"
  },
  "license": "MIT",
  "author": "K Huehn <slowebworkz@gmail.com>",
  "description": "Praxis Kit adapter for React 18 and 19 — polymorphic components with ARIA contracts and variant composition",
  "keywords": [
    "praxis-kit",
    "polymorphic",
    "ui",
    "components",
    "accessibility",
    "aria",
    "typescript",
    "framework-agnostic",
    "contract",
    "variants",
    "react"
  ],
  "engines": {
    "node": ">=18"
  }
}
