{
  "name": "@polymorphic-ui/react",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./legacy": {
      "types": "./dist/legacy/index.d.ts",
      "import": "./dist/legacy/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --fix --config eslint.config.ts",
    "lint:check": "eslint . --config eslint.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:related": "vitest run --changed",
    "prepublishOnly": "pnpm build",
    "lint:pkg": "publint"
  },
  "sideEffects": false,
  "dependencies": {
    "@polymorphic-ui/adapter-utils": "workspace:*",
    "@polymorphic-ui/core": "workspace:*",
    "clsx": "catalog:",
    "type-fest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
